// ONEWAY
// RENAME fabric.mod.json
{
  "schemaVersion": 1,
  "id": "queqiao",
  "version": "${version}",
  "name": "QueQiao",
  "description": "Minecraft Server Mod/Plugin for Real-time Player Events & API Broadcast Messaging",
  "authors": [
    "17TheWord"
  ],
  "contact": {
    "homepage": "https://github.com/17TheWord/QueQiao",
    "sources": "https://github.com/17TheWord/QueQiao",
    "issues": "https://github.com/17TheWord/QueQiao/issues",
    "email": "17theword@gmail.com"
  },
  "license": "MIT",
  "icon": "queqiao/logo.png",
  "environment": "server",
  "entrypoints": {
    "main": [
      "com.github.theword.queqiao.QueQiao"
    ]
  },
  "mixins": [
    "queqiao.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=${loader_version}",
    "fabric": "*",
    // IF fabric-1.21.9
    // "minecraft": ["1.21.9", "1.21.10"]
    // ELSE IF fabric-1.21.6
    // "minecraft": ["1.21.6", "1.21.7", "1.21.8"]
    // ELSE IF fabric-1.20.1
    // "minecraft": ["1.20.1", "1.20.2"]
    // ELSE
    // "minecraft": "${minecraft_version}"
    // END IF
  }
}